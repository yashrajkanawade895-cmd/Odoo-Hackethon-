# Copy this file to .env and fill in your own values. NEVER commit .env
#
# SHARED CLOUD DB (recommended for the team): paste the connection string Neon
# gives you (all 3 teammates use the SAME one, so you seed just once):
#   DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.neon.tech/bento?sslmode=require"
#
# LOCAL DB (offline / solo): use your own local Postgres password instead:
#   DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/bento"
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/bento"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=5000


